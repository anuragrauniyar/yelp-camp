<% layout('layouts/boilerplate')%>
<div id="cluster-map"></div>
<div class="container mt-4">
    
    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
        <div class="mb-4 d-flex justify-content-start align-items-center">
            <a href="/campgrounds" class="btn btn-sm <%= !isFilteringDashboard ? 'btn-primary' : 'btn-outline-primary' %> mr-2">
                All Campgrounds
            </a>
            <a href="/campgrounds?filter=mine" class="btn btn-sm <%= isFilteringDashboard ? 'btn-primary' : 'btn-outline-primary' %>">
                My Listed Campgrounds (<%= myListingsCount %>)
            </a>
        </div>
    <% } %>

    <h1><%= isFilteringDashboard ? "My Listed Accommodations" : "All Campgrounds" %></h1>

    <% for (let campground of campgrounds){%>
    <div class="card mb-3">
        <div class="row">
            <div class="col-md-4">
                <%if(campground.images.length) {%>
                <img class="img-fluid" alt="" src="<%=campground.images[0].url%>">
                <% }else {%>
                <img crossorigin="anonymous" class="img-fluid" alt=""
                    src="https://res.cloudinary.com/douqbebwk/image/upload/v1600103881/YelpCamp/lz8jjv2gyynjil7lswf4.png">
                <% } %>
            </div>
            <div class="col-md-8">
                <div class="card-body">
                    <h5 class="card-title"><%= campground.title %> </h5>

                    <p class="card-text"><%= campground.description %></p>
                    <p class="card-text">
                        <small class="text-muted"><%= campground.location%></small>
                    </p>
                    <a class="btn btn-primary" href="/campgrounds/<%=campground._id%>">View <%=campground.title%></a>
                </div>
            </div>
        </div>
    </div>
    <% }%>
</div>

<script>
    const campgroundsData = <%- JSON.stringify(campgrounds) %>;
</script>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.Default.css" />
<script src="https://unpkg.com/leaflet.markercluster@1.4.1/dist/leaflet.markercluster.js"></script>

<script>
    // 4. Fallback execution vector to prevent layout engine crashes
    document.addEventListener("DOMContentLoaded", function () {
        const mapContainer = document.getElementById('cluster-map');
        if (!mapContainer) return;

        // Initialize a clean Leaflet instance focused globally over India/Default region
        const map = L.map('cluster-map').setView([20.5937, 78.9629], 5);

        // Render the OpenStreetMap mapnik tile layout layer
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 18,
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        // Instantiate the marker clustering subsystem layer group
        const markers = L.markerClusterGroup();

        // Safety verification: ensure your database objects contain real geographic coordinates
        if (campgroundsData && campgroundsData.length > 0) {
            const coordinatesArray = [];

            campgroundsData.forEach(function (camp) {
                if (camp.geometry && camp.geometry.coordinates) {
                    const lon = camp.geometry.coordinates[0];
                    const lat = camp.geometry.coordinates[1];
                    
                    // Leaflet coordinates system uses strict [Latitude, Longitude] sequencing
                    const marker = L.marker([lat, lon]);
                    
                    // Bind interactive hover popup windows containing database linkages
                    marker.bindPopup(`
                        <h6><a href="/campgrounds/${camp._id}">${camp.title}</a></h6>
                        <p class="text-muted">${camp.location}</p>
                    `);
                    
                    markers.addLayer(marker);
                    coordinatesArray.push([lat, lon]);
                }
            });

            // Append the clustered marker dataset directly onto the live tile canvas layer
            map.addLayer(markers);

            // Automatically pan and zoom the screen boundary box to snap cleanly onto your camps
            if (coordinatesArray.length > 0) {
                map.fitBounds(coordinatesArray, { padding: [50, 50] });
            }
        }
        console.log("🚀 Leaflet Data Clusters mounted and rendered successfully.");
    });
</script>
